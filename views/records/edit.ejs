<%- include("../partials/header") %>
<div class="container">
    <div class="row">
        <h1 style="text-align: center">Edit <%= record.name %></h1>
        <div style="width: 30%; margin: 25px auto;">
            <form action="/records/<%= record._id %>?_method=PUT" method="POST">
                <div class="form-group">
                    <input class="form-control" type="text" name="record[artist]" value="<%= record.artist %>">
                </div>
                  <div class="form-group">
                    <input class="form-control" type="text" name="record[album]" value="<%= record.album %>">
                </div>
                <div class="form-group">
                    <input class="form-control" type="text" name="record[image]" value="<%= record.image %>">
                </div>
                  <div class="form-group">
                    <input class="form-control" type="text" name="record[year]" value="<%= record.year %>">
                </div>
                <div class="form-group">
                    <input class="form-control" type="text" name="record[found]" value="<%= record.found %>">
                </div>
                <div class="form-group">
                    <button class="btn btn-lg btn-primary btn-block">Submit!</button>
                </div>
            </form>
            <a href="/records">Go Back</a>
        </div>
    </div>
</div>
<%- include("../partials/footer") %>

